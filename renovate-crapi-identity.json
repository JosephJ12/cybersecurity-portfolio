{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": "Automated dependency remediation for the crapi-identity authentication service for OWASP crAPI DevSecOps pipeline project.",
    "extends": [
      "config:recommended",
      "security:openssf-scorecard"
    ],
    "dependencyDashboard": true,
    "labels": ["dependencies", "security", "devsecops"],
    "prHourlyLimit": 4,
    "prConcurrentLimit": 10,
    "rangeStrategy": "bump",
    "packageRules": [
      {
        "description": "Prioritize critical security fixes",
        "matchDatasources": ["maven"],
        "matchUpdateTypes": ["patch", "minor"],
        "labels": ["security", "critical-remediation"],
        "automerge": true,
        "automergeType": "pr",
        "requiredStatusChecks": [
          "Trivy Identity Image Scan",
          "Semgrep SAST"
        ]
      },
      {
        "description": "Group Spring ecosystem updates",
        "matchPackagePatterns": [
          "^org\\.springframework",
          "^org\\.springframework\\.boot",
          "^org\\.springframework\\.security"
        ],
        "groupName": "spring ecosystem security updates",
        "labels": ["spring", "security"]
      },
      {
        "description": "Group Tomcat embedded updates",
        "matchPackagePatterns": [
          "^org\\.apache\\.tomcat\\.embed"
        ],
        "groupName": "tomcat embedded security updates",
        "labels": ["tomcat", "security"]
      },
      {
        "description": "Group Log4j updates",
        "matchPackagePatterns": [
          "^org\\.apache\\.logging\\.log4j"
        ],
        "groupName": "log4j security updates",
        "labels": ["log4j", "security"]
      },
      {
        "description": "Group PostgreSQL JDBC updates",
        "matchPackagePatterns": [
          "^org\\.postgresql"
        ],
        "groupName": "postgresql jdbc security updates",
        "labels": ["postgresql", "security"]
      },
      {
        "description": "Require manual review for major updates",
        "matchUpdateTypes": ["major"],
        "automerge": false,
        "labels": ["major-update", "manual-review-required"]
      },
      {
        "description": "Update GitHub Actions safely",
        "matchManagers": ["github-actions"],
        "groupName": "github actions updates",
        "automerge": true,
        "automergeType": "pr"
      },
      {
        "description": "Update Docker images safely",
        "matchDatasources": ["docker"],
        "groupName": "docker base image updates",
        "automerge": false,
        "labels": ["container-security", "manual-review-required"]
      }
    ]
  }